{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "patient_name": {
      "type": "string",
      "description": "Full name of the patient"
    },
    "patient_email": {
      "type": "string",
      "format": "email"
    },
    "patient_phone": {
      "type": "string"
    },
    "department": {
      "type": "string",
      "enum": [
        "cardiology",
        "neurology",
        "orthopedics",
        "pediatrics",
        "dermatology",
        "general_medicine"
      ]
    },
    "doctor": {
      "type": "string"
    },
    "appointment_date": {
      "type": "string",
      "format": "date"
    },
    "appointment_time": {
      "type": "string"
    },
    "reason": {
      "type": "string",
      "description": "Reason for visit"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    }
  },
  "required": [
    "patient_name",
    "patient_email",
    "patient_phone",
    "department",
    "appointment_date"
  ]
}
