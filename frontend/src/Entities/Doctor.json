{
  "name": "Doctor",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string"
    },
    "specialization": {
      "type": "string",
      "enum": [
        "cardiology",
        "neurology",
        "orthopedics",
        "pediatrics",
        "dermatology",
        "general_medicine"
      ]
    },
    "qualifications": {
      "type": "string"
    },
    "experience_years": {
      "type": "number"
    },
    "bio": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "availability": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["full_name", "specialization"]
}
